{
	"name" : "concrete5/community_translation",
	"type" : "concrete5-package",
	"description" : "An open source online and collaborative translation system",
	"license" : "MIT",
	"homepage" : "https://github.com/concrete5/addon_community_translation",
	"support" : {
		"issues" : "https://github.com/concrete5/addon_community_translation/issues",
		"source" : "https://github.com/concrete5/addon_community_translation"
	},
	"keywords" : [
		"translation",
		"localization",
		"l10n",
		"internationalization",
		"i18n",
		"online",
		"collaborative",
		"concrete5"
	],
	"archive" : {
		"exclude" : [
			"/build",
			"/test",
			"/.gitattributes",
			"/.travis.yml",
			"/phpunit.xml"
		]
	},
	"require-dev" : {
		"php": ">=7",
		"concrete5/core" : "dev-develop",
		"phpunit/phpunit" : "^6.1",
		"symfony/process": "3.*"
	},
	"autoload-dev" : {
		"psr-4" : {
			"CommunityTranslation\\Tests\\" : "test/tests",
			"CommunityTranslation\\" : "src"
		}
	},
	"scripts" : {
		"test" : "phpunit --verbose"
	}
}
